graph TB
  subgraph SRC[Python Source]
    INFRA[Infrastructure - link_budget + rf_link_budget]
    ROUTE[Routing - rl_agent + bundle + ltp + tcpcl]
    SEC[Security - qkd + repeater_chain]
    ORBIT[Orbital - contact_windows + topology + doppler]
  end
  subgraph ENGINE[Simulation Engine]
    SIM[simulator]
    POLICY[policy_engine]
    TRAIN[training + multi_agent]
    FWD[forwarding_engine]
  end
  subgraph WEB[Web Showcase - 10 Demos]
    DASH[Mission Control]
    LB[Link Budget]
    RL[RL Routing]
    QKD[QKD Protocol]
    ORB[Orbital Mechanics]
    DTN[DTN Engine]
    MISS[Mars Mission]
  end
  INFRA --> SIM
  ROUTE --> SIM
  SEC --> SIM
  ORBIT --> SIM
  SIM --> POLICY
  SIM --> TRAIN
  SIM --> FWD
  POLICY --> DASH
  FWD --> DTN
