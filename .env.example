# AETHERIX Environment Configuration
# Copy this file to .env and adjust values

# --- General ---
APP_NAME=AETHERIX
DEBUG=true
LOG_LEVEL=INFO

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_URL=/api

# --- Database (local dev uses SQLite, Docker uses PostgreSQL) ---
DATABASE_URL=sqlite:///./aetherix.db

# --- PostgreSQL (Docker only) ---
POSTGRES_DB=aetherix
POSTGRES_USER=aetherix
POSTGRES_PASSWORD=aetherix_dev
POSTGRES_PORT=5432

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
