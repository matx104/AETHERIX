# AETHERIX Backend Environment Configuration
# Copy to .env and adjust as needed:
#   cp .env.example .env

APP_NAME=AETHERIX
APP_VERSION=3.0.0
DEBUG=true

# SQLite (local dev) or PostgreSQL (Docker)
# Local:    sqlite:///./aetherix.db
# Docker:   postgresql://aetherix:aetherix@db:5432/aetherix
DATABASE_URL=sqlite:///./aetherix.db

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS — add origins for frontend dev servers
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
