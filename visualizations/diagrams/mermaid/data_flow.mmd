graph TD
  subgraph APP[Application Layer]
    SRC[1 Source Node]
    BP[2 Bundle Protocol BPv7]
    RL[3 RL Routing]
    QE[4 QKD Encrypt]
  end
  subgraph CONV[Convergence Layer]
    LTP[5 LTP Segmentation]
    STORE[6 Store and Wait]
    FWD[7 Forward and Custody]
  end
  subgraph PHYS[Physical Layer]
    UHF[Mars UHF]
    ISL[Optical ISL]
    DEEP[Deep Space 1550nm]
    KAB[DSN Ka-band]
  end
  subgraph DELIV[Delivery]
    RASM[8 LTP Reassemble]
    DEC[9 QKD Decrypt]
    DEL[10 Delivered to JPL]
  end
  SRC --> BP --> RL --> QE
  QE --> LTP --> STORE --> FWD
  FWD --> UHF
  FWD --> ISL
  FWD --> DEEP
  FWD --> KAB
  UHF --> RASM
  ISL --> RASM
  DEEP --> RASM
  KAB --> RASM
  RASM --> DEC --> DEL
